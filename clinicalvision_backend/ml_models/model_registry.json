{
  "registry_version": "1.0",
  "active_model": "v12_production",
  "models": {
    "v12_production": {
      "version": "v12_production",
      "description": "DenseNet-121 ROI ensemble with MC Dropout uncertainty",
      "created_at": "2026-02-02",
      "architecture": {
        "backbone": "DenseNet121",
        "dense_units": 2048,
        "dropout_rate": 0.35,
