# =============================================================================
# ClinicalVision AI - Production Environment Configuration
# =============================================================================
# 
# IMPORTANT: This file contains sensitive configuration values.
# Never commit this file to version control.
# Copy to .env and configure with your production values.
#
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application name and version
APP_NAME=ClinicalVision AI
APP_VERSION=1.0.0

# Environment: development, staging, production
ENVIRONMENT=production

# Debug mode (disable in production)
DEBUG=false

# Frontend URL (for email links)
APP_URL=https://clinicalvision.ai

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Host and port
HOST=0.0.0.0
PORT=8000

# Workers (adjust based on CPU cores)
WORKERS=4

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# 
# For production, use:
# - AWS RDS PostgreSQL (HIPAA eligible)
# - Azure Database for PostgreSQL
# - Google Cloud SQL for PostgreSQL
# - Self-managed PostgreSQL with encryption
#

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://clinicalvision:CHANGE_THIS_PASSWORD@db.production.clinicalvision.ai:5432/clinicalvision_db

# Individual database parameters (used by Docker Compose)
DB_USER=clinicalvision
DB_PASSWORD=CHANGE_THIS_PASSWORD
DB_NAME=clinicalvision_db
DB_HOST=db.production.clinicalvision.ai
DB_PORT=5432

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret Key (CRITICAL: Generate a secure 256-bit key)
# Generate with: openssl rand -hex 32
SECRET_KEY=GENERATE_A_SECURE_256_BIT_KEY_HERE

# JWT Algorithm
ALGORITHM=HS256

# Token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# =============================================================================
# AUTH0 CONFIGURATION (Optional - Enterprise SSO)
# =============================================================================
# 
# For enterprise deployments, configure Auth0 for:
# - Single Sign-On (SSO)
# - Multi-factor Authentication (MFA)
# - Social login providers
# - Enterprise identity providers (SAML, LDAP)
#

# Enable Auth0 authentication
AUTH0_ENABLED=false

# Auth0 domain (e.g., yourapp.auth0.com)
AUTH0_DOMAIN=

# Auth0 application credentials
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Auth0 API audience/identifier
AUTH0_AUDIENCE=https://api.clinicalvision.ai

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
#
# For production, use:
# - AWS SES (Amazon Simple Email Service)
# - SendGrid
# - Mailgun
# - Postmark
#

# Enable email sending
EMAIL_ENABLED=true

# SMTP server settings
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false

# SMTP credentials
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Email sender information
EMAIL_FROM=noreply@clinicalvision.ai
EMAIL_FROM_NAME=ClinicalVision AI

# Token expiration settings
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1

# =============================================================================
# REDIS CONFIGURATION (Caching & Sessions)
# =============================================================================

# Redis connection URL
REDIS_URL=redis://redis:6379/0

# Redis password
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Use mock model for testing (disable in production)
USE_MOCK_MODEL=false

# Model file path
MODEL_PATH=models/best_model.pth

# Model inference timeout (seconds)
MODEL_TIMEOUT=300

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Upload directory
UPLOAD_DIR=uploads

# Maximum upload size (bytes) - 100MB for mammograms
MAX_UPLOAD_SIZE=104857600

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=json

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins (comma-separated)
CORS_ORIGINS=["https://clinicalvision.ai","https://www.clinicalvision.ai"]

# =============================================================================
# RATE LIMITING
# =============================================================================

# Rate limit per minute for API endpoints
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Enable Prometheus metrics
METRICS_ENABLED=true

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# =============================================================================
# HIPAA COMPLIANCE SETTINGS
# =============================================================================

# Enable audit logging
AUDIT_LOGGING_ENABLED=true

# Session timeout (minutes)
SESSION_TIMEOUT_MINUTES=30

# Require strong passwords
REQUIRE_STRONG_PASSWORDS=true

# Minimum password length
MIN_PASSWORD_LENGTH=12

# =============================================================================
# DOCKER / DEPLOYMENT PORTS
# =============================================================================

# Backend API port
BACKEND_PORT=8000

# Frontend port (mapped from nginx 80)
FRONTEND_PORT=80
FRONTEND_SSL_PORT=443

# Database port (internal)
DB_PORT=5432

# Redis port (internal)
REDIS_PORT=6379
