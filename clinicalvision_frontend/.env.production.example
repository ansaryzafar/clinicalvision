# =============================================================================
# ClinicalVision AI - Frontend Environment Configuration
# =============================================================================
# 
# React environment variables must be prefixed with REACT_APP_
# These are compiled into the build and are NOT secret.
#
# =============================================================================

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API URL
REACT_APP_API_URL=https://api.clinicalvision.ai

# API version
REACT_APP_API_VERSION=v1

# =============================================================================
# AUTH0 CONFIGURATION (Optional - Enterprise SSO)
# =============================================================================

# Auth0 domain (e.g., yourapp.auth0.com)
REACT_APP_AUTH0_DOMAIN=

# Auth0 application client ID (public - safe to expose)
REACT_APP_AUTH0_CLIENT_ID=

# Auth0 API audience
REACT_APP_AUTH0_AUDIENCE=https://api.clinicalvision.ai

# Auth0 callback URL (after login)
REACT_APP_AUTH0_REDIRECT_URI=https://clinicalvision.ai/auth/callback

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application name
REACT_APP_NAME=ClinicalVision AI

# Application version
REACT_APP_VERSION=1.0.0

# Environment indicator
REACT_APP_ENVIRONMENT=production

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Auth0 login option
REACT_APP_ENABLE_AUTH0=false

# Enable demo mode features
REACT_APP_ENABLE_DEMO=false

# Enable analytics
REACT_APP_ENABLE_ANALYTICS=true

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics ID
REACT_APP_GA_ID=

# Sentry DSN for error tracking
REACT_APP_SENTRY_DSN=

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Support email
REACT_APP_SUPPORT_EMAIL=support@clinicalvision.ai

# Documentation URL
REACT_APP_DOCS_URL=https://docs.clinicalvision.ai
