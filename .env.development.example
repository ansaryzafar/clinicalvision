# =============================================================================
# ClinicalVision AI - Development Environment Configuration
# =============================================================================
# 
# This file is for LOCAL DEVELOPMENT only.
# Copy to .env and customize as needed.
#
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

APP_NAME=ClinicalVision AI
APP_VERSION=1.0.0-dev
ENVIRONMENT=development
DEBUG=true
APP_URL=http://localhost:3000

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

HOST=0.0.0.0
PORT=8000
WORKERS=1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Local PostgreSQL (use Docker or local installation)
DATABASE_URL=postgresql://clinicalvision:vision123@localhost:5432/clinicalvision_db

# Docker Compose database settings
DB_USER=clinicalvision
DB_PASSWORD=vision123
DB_NAME=clinicalvision_db
DB_PORT=15432

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Development secret key (NEVER use in production!)
SECRET_KEY=dev-secret-key-for-local-development-only-change-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# AUTH0 CONFIGURATION (Optional)
# =============================================================================

AUTH0_ENABLED=false
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Disable email in development (logs emails instead)
EMAIL_ENABLED=false

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=

EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=ClinicalVision AI (Dev)

EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_dev_password
REDIS_PORT=6380

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Use mock model for development (faster startup)
USE_MOCK_MODEL=true
MODEL_PATH=models/best_model.pth

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

LOG_LEVEL=DEBUG
LOG_FORMAT=text

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# =============================================================================
# RATE LIMITING (relaxed for development)
# =============================================================================

RATE_LIMIT_PER_MINUTE=1000

# =============================================================================
# DOCKER COMPOSE PORTS (local development)
# =============================================================================

BACKEND_PORT=8001
FRONTEND_PORT=3001
FRONTEND_SSL_PORT=3443
